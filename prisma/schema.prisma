generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model knihy {
  id             String   @id @db.VarChar(255)
  name           String?  @db.VarChar(255)
  author         String?  @db.VarChar(255)
  category       String?  @db.VarChar(50)
  genres         String[]
  signatura      String?  @db.VarChar(50)
  zpusob_ziskani String?  @db.VarChar(100)
  formaturita    Boolean?
  available      Boolean?
  rating         Int?
  isbn           String?  @db.VarChar(13)
  createdat DateTime @default(now())
  updatedat DateTime @updatedAt // Automatically updates on changes
}

model backups {
  id         String   @id @db.VarChar(255)
  adminname       String? @db.VarChar(255)
  backupat   DateTime @default(now())
}

model opening_hours {
  id    String  @id @db.VarChar(20)
  day   String  @db.VarChar(50)
  open  String? @db.VarChar(10)
  close String? @db.VarChar(10)
}

